<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.view.Relatorio.RelatorioController">

    <!-- Área Central do Conteúdo -->
    <center>
        <VBox prefHeight="650.0" prefWidth="897.0" spacing="20.0" style="-fx-background-color: #f8fafc; -fx-padding: 25;" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Visão Geral do Negócio" />

                <!-- Seção de Cards (KPIs) -->
                <HBox spacing="20.0">
                    <children>
                        <!-- Card 1 -->
                        <VBox prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                            <children>
                                <Label style="-fx-font-size: 14; -fx-text-fill: #64748b;" text="Funcionários Ativos" />
                                <Label fx:id="funcionario" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="0" />
                            </children>
                        </VBox>

                        <!-- Card 2 -->
                        <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                            <children>
                                <Label style="-fx-font-size: 14; -fx-text-fill: #64748b;" text="Folha Salarial Atual" />
                                <Label fx:id="Salario" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="R$ 0,00" />
                            </children>
                        </VBox>
                  <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <children>
                        <Label style="-fx-font-size: 14; -fx-text-fill: #64748b;" text="Despesas" />
                        <Label fx:id="Despesas" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="R$ 0,00" />
                     </children>
                  </VBox>
                  <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <children>
                        <Label style="-fx-font-size: 14; -fx-text-fill: #64748b;" text="Inconsistências no Registro" />
                        <Label fx:id="Registro" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="0" />
                     </children>
                  </VBox>
                    </children>
                </HBox>

                <!-- Seção de Gráficos -->
                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Gráfico de Pizza -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10;" HBox.hgrow="ALWAYS">
                            <children>
                                <PieChart fx:id="TBdepartamento" title="Funcionários por Departamento" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <!-- Gráfico de Barras -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 10;" HBox.hgrow="ALWAYS">
                            <children>
                                <BarChart fx:id="TBDespesas" title="Custos por Tipo de Despesa" VBox.vgrow="ALWAYS">
                                    <xAxis>
                                        <CategoryAxis side="BOTTOM" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis side="LEFT" />
                                    </yAxis>
                                </BarChart>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
