         </children>
      </AnchorPane>
      <AnchorPane layoutY="425.0" prefHeight="49.0" prefWidth="827.0">
         <children>
            <Button layoutX="682.0" layoutY="12.0" mnemonicParsing="false" text="Adicionar" />
            <Button layoutX="616.0" layoutY="12.0" mnemonicParsing="false" text="Deletar" />
            <Button layoutX="760.0" layoutY="12.0" mnemonicParsing="false" text="Salvar" />
         </children>
      </AnchorPane>
      <AnchorPane layoutY="43.0" prefHeight="382.0" prefWidth="827.0">
