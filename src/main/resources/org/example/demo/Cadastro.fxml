                  <TableColumn fx:id="Status" prefWidth="68.0" text="Status" />
                  <TableColumn fx:id="Departamento" prefWidth="97.0" text="Departamento" />
              </columns>
            </TableView>
         </children>
      </AnchorPane>
   </children>
