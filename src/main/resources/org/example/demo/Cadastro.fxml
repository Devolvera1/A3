               <image>
                  <Image url="@img/Logo.png" />
               </image>
            </ImageView>
            <Button fx:id="Fechar" layoutX="781.0" layoutY="9.0" mnemonicParsing="false" onAction="#Fechar" prefHeight="25.0" prefWidth="28.0" text="X" />
