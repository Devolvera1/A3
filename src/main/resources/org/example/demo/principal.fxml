                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>

                <Line endX="88.0" layoutX="96.0" layoutY="183.0" startX="-82.5" stroke="WHITE" />

                <ImageView fitHeight="69.0" fitWidth="125.0" layoutX="62.0" layoutY="46.0" pickOnBounds="true" preserveRatio="true">
