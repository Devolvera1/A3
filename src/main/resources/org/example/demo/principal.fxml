                <Button layoutX="14.0" layoutY="250.0" onAction="#AbrirRelatorio" prefHeight="30.0" prefWidth="172.0" style="-fx-background-color: #3a7bfc; -fx-border-color: #FFFFFF; -fx-font-weight: Bold; -fx-alignment: Center;" text="Relatório" textAlignment="CENTER" textFill="WHITE" />
