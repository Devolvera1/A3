                <Button fx:id="Cadastro" layoutX="14.0" layoutY="210.0" onAction="#abrirCadastro" prefHeight="30.0" prefWidth="172.0" style="-fx-background-color: #3a7bfc; -fx-border-color: #FFFFFF; -fx-font-weight: Bold; -fx-alignment: Center;" text="Cadastro" textAlignment="CENTER" textFill="WHITE" />
